{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/agent-store-marketplace.schema.json",
  "title": "Agent Store Marketplace Catalog",
  "type": "object",
  "required": [
    "name",
    "plugins"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
    },
    "interface": {
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "policy",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
          },
          "source": {
            "type": "object",
            "required": [
              "source",
              "path"
            ],
            "properties": {
              "source": {
                "const": "local"
              },
              "path": {
                "type": "string",
                "pattern": "^\\./"
              }
            },
            "additionalProperties": false
          },
          "policy": {
            "type": "object",
            "required": [
              "installation",
              "authentication"
            ],
            "properties": {
              "installation": {
                "enum": [
                  "NOT_AVAILABLE",
                  "AVAILABLE",
                  "INSTALLED_BY_DEFAULT"
                ]
              },
              "authentication": {
                "enum": [
                  "ON_INSTALL",
                  "ON_USE"
                ]
              }
            },
            "additionalProperties": true
          },
          "category": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
